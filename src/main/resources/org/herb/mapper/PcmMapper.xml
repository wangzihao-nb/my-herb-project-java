<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.herb.mapper.PcmMapper">
    <!--    动态sql-->
    <select id="list" resultType="org.herb.pojo.Pcm">
        select * from pcm
        <where>

            <if test="dosageForm != null">
                dosage_form=#{dosageForm}
            </if>

            <if test="type != null">
                and type like concat('%',#{type},'%')
            </if>

            <if test="pcmName != null">
                and pcm_name like concat('%',#{pcmName},'%')
            </if>


        </where>

    </select>

</mapper>