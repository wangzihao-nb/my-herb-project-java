<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.herb.mapper.UserMapper">
    <!--    动态sql-->
    <select id="list" resultType="org.herb.pojo.User">
        select * from user
        <where>

            role != 'ROLE_ADMIN'

            <if test="username != null">
                and username=#{username}
            </if>

        </where>

    </select>

</mapper>