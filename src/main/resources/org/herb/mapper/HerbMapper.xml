<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.herb.mapper.HerbMapper">
    <!--    动态sql-->
    <select id="list" resultType="org.herb.pojo.Herb">
        select * from herb
        <where>

            <if test="family != null">
                family=#{family}
            </if>

            <if test="category != null">
                and category like concat('%',#{category},'%')
            </if>

            <if test="property != null">
                and property like concat('%',#{property},'%')
            </if>

            <if test="flavor != null">
                and flavor like concat('%',#{flavor},'%')
            </if>

            <if test="meridianTropism != null">
                and meridian_tropism like concat('%',#{meridianTropism},'%')
            </if>

            <if test="cnName != null">
                and cn_name like concat('%',#{cnName},'%')
            </if>

        </where>

    </select>

</mapper>