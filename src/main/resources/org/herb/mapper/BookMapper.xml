<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.herb.mapper.BookMapper">
    <!--    动态sql-->
    <select id="list" resultType="org.herb.pojo.Book">
        select * from book
        <where>

            <if test="type != null">
                type=#{type}
            </if>

            <if test="bookName != null">
                and book_name like concat('%',#{bookName},'%')
            </if>

        </where>

    </select>

</mapper>